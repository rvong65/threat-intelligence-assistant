# ---------------------------------------------------------------------------
# Threat Intelligence Assistant — environment configuration
# Copy to .env and adjust. GROQ_API_KEY is optional here; it is read from
# os.environ (shell, IDE secrets, Streamlit Secrets). Never commit the key.
# ---------------------------------------------------------------------------

# Deployment profile: local | cloud
# cloud auto-defaults: LLM=groq, embeddings=huggingface, LLM_REWRITE_FOLLOWUPS=false
DEPLOYMENT_PROFILE=local

# LLM provider: ollama | groq | together
LLM_PROVIDER=ollama
# Local: gemma3:4b. Cloud (Groq): llama-3.1-8b-instant
LLM_MODEL=gemma3:4b

# Optional in this file — set in your environment or Streamlit Secrets instead.
GROQ_API_KEY=

# Together.ai (optional fallback)
TOGETHER_API_KEY=

# Ollama (local LLM + local embeddings when DEPLOYMENT_PROFILE=local)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding provider: ollama | huggingface | openai_compatible
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
HUGGINGFACE_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
# Pinned commit — do not use "main"; see config/settings.py HUGGINGFACE_NOMIC_EMBED_REVISION
HUGGINGFACE_EMBEDDING_REVISION=3ac47f125a41961d13b397d0332866be2f9152e1

# Vector store backend: faiss (default, cloud-safe) | chroma (local only)
VECTORSTORE_BACKEND=faiss

# RAG retrieval and confidence
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=40
HARD_ABSTENTION_ENABLED=true
LLM_REWRITE_FOLLOWUPS=true
INCLUDE_GROUPS_SOFTWARE=true
MEMORY_MAX_TURNS=3
INGEST_BATCH_SIZE=32

# Paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
INDICES_DIR=indices/faiss_index

# ---------------------------------------------------------------------------
# Streamlit Cloud / Groq simulation (maintainer — set GROQ_API_KEY in Secrets):
#
# DEPLOYMENT_PROFILE=cloud
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant
# EMBEDDING_PROVIDER=huggingface
# LLM_REWRITE_FOLLOWUPS=false
# ---------------------------------------------------------------------------
