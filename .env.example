# ---------------------------------------------------------------------------
# Threat Intelligence Assistant — environment configuration
#
# Default profile: cloud (Streamlit Community Cloud + Groq + HuggingFace).
# Copy to .env for local runs, or mirror these keys in Streamlit Secrets.
# GROQ_API_KEY: set in your shell, IDE, or Streamlit Secrets — never commit it.
# ---------------------------------------------------------------------------

DEPLOYMENT_PROFILE=cloud
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Optional in this file — prefer environment or Streamlit Secrets for the real key.
GROQ_API_KEY=

# Together.ai (optional fallback)
TOGETHER_API_KEY=

# Ollama (local development only — see block at bottom)
OLLAMA_BASE_URL=http://localhost:11434

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=nomic-embed-text
HUGGINGFACE_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
# Pinned commit — do not use "main"; see config/settings.py HUGGINGFACE_NOMIC_EMBED_REVISION
HUGGINGFACE_EMBEDDING_REVISION=3ac47f125a41961d13b397d0332866be2f9152e1

# Vector store backend: faiss (default, cloud-safe) | chroma (local only)
VECTORSTORE_BACKEND=faiss

# RAG retrieval and confidence
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=40
HARD_ABSTENTION_ENABLED=true
LLM_REWRITE_FOLLOWUPS=false
INCLUDE_GROUPS_SOFTWARE=true
MEMORY_MAX_TURNS=3
INGEST_BATCH_SIZE=32

# Paths (relative to project root)
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
INDICES_DIR=indices/faiss_index

# ---------------------------------------------------------------------------
# Local development (Ollama) — replace the cloud values above:
#
# DEPLOYMENT_PROFILE=local
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:4b
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# LLM_REWRITE_FOLLOWUPS=true
#
# Requires: ollama pull nomic-embed-text && ollama pull gemma3:4b
# ---------------------------------------------------------------------------
